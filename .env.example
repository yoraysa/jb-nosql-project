# Copy this file to .env and fill in your values.
# Docker Compose services use the service names below as hostnames.
# If you run databases locally (not via Docker), use "localhost" instead.

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=ecommerce

# ── Redis (Phase 2) ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Neo4j (Phase 3) ────────────────────────────────────────────────────────
NEO4J_HOST=localhost
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword
